# CareerPilot AI Backend - Environment Configuration Example
# Copy this file to .env and modify values as needed

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=CareerPilot AI
API_VERSION=1.0.0
API_DESCRIPTION=AI-powered career intelligence and skill analysis platform

# Debug Mode (True/False)
DEBUG=False

# Dataset Configuration
DATASET_DIR=./dataset
FALLBACK_ON_MISSING_DATA=true

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Database Configuration (for future use)
DATABASE_URL=postgresql://user:password@localhost/careerpilot
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20

# Redis Configuration (for caching, future use)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Authentication (future use)
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# Third-party API Keys (future use)
OPENAI_API_KEY=sk-xxx
LINKEDIN_API_KEY=xxx
INDEED_API_KEY=xxx

# Email Configuration (future use)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-password
SENDER_EMAIL=noreply@careerpilot.ai

# File Upload Configuration
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_UPLOAD_TYPES=.pdf,.doc,.docx,.txt

# Performance Configuration
CACHE_ENABLED=true
COMPRESSION_ENABLED=true
REQUEST_TIMEOUT=30

# Feature Flags
ENABLE_FILE_UPLOAD=true
ENABLE_AUTHENTICATION=false
ENABLE_DATABASE=false
ENABLE_REDIS_CACHE=false
ENABLE_WEBSOCKETS=false
ENABLE_REALTIME_UPDATES=false

# Monitoring & Analytics
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Worker Configuration
WORKER_THREADS=4
WORKER_PROCESSES=1

# Rate Limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Run Mode (development/production)
RUN_MODE=development
